{
  "elements": [
    {
      "type": "ExpansionPanel",
      "caption": "Temperaturen",
      "expanded": true,
      "items": [
        {
          "type": "SelectVariable",
          "name": "TargetTemperatureID",
          "caption": "Solltemperatur (AHC Soll-Wert, Float)",
          "validVariableTypes": [2]
        },
        {
          "type": "SelectVariable",
          "name": "ActualTemperatureID",
          "caption": "Isttemperatur (Raumfühler, Float)",
          "validVariableTypes": [2]
        },
        {
          "type": "NumberSpinner",
          "name": "TempMin",
          "caption": "Minimum Solltemperatur (°C)",
          "digits": 1,
          "minimum": 4,
          "maximum": 15,
          "suffix": " °C"
        },
        {
          "type": "NumberSpinner",
          "name": "TempMax",
          "caption": "Maximum Solltemperatur (°C)",
          "digits": 1,
          "minimum": 16,
          "maximum": 35,
          "suffix": " °C"
        },
        {
          "type": "NumberSpinner",
          "name": "TempStep",
          "caption": "Schrittweite +/- Tasten (°C)",
          "digits": 1,
          "minimum": 0.1,
          "maximum": 2.0,
          "suffix": " °C"
        }
      ]
    },
    {
      "type": "ExpansionPanel",
      "caption": "Heizung / Modus",
      "expanded": true,
      "items": [
        {
          "type": "SelectVariable",
          "name": "HeatingModeID",
          "caption": "Betriebsmodus (AHC HeatingMode, Integer)",
          "validVariableTypes": [1]
        },
        {
          "type": "Label",
          "caption": "Moduswerte: 0=Aus, 1=Heizen, 2=Kühlen, 3=Eco, 4=Boost (je nach AHC-Profil anpassen)"
        },
        {
          "type": "List",
          "name": "ModeMapping",
          "caption": "Modus-Zuordnung",
          "rowCount": 5,
          "add": true,
          "delete": true,
          "columns": [
            {
              "caption": "Wert",
              "name": "Value",
              "width": "80px",
              "edit": { "type": "NumberSpinner", "digits": 0 }
            },
            {
              "caption": "Bezeichnung",
              "name": "Label",
              "width": "140px",
              "edit": { "type": "ValidationTextBox" }
            },
            {
              "caption": "Farbe",
              "name": "Color",
              "width": "160px",
              "edit": {
                "type": "Select",
                "options": [
                  { "caption": "Heizen (orange)", "value": "heat" },
                  { "caption": "Kühlen (blau)",   "value": "cold" },
                  { "caption": "Eco (grün)",       "value": "eco"  },
                  { "caption": "Aus (grau)",        "value": "off"  }
                ]
              }
            }
          ],
          "values": [
            { "Value": 0, "Label": "Aus",    "Color": "off"  },
            { "Value": 1, "Label": "Heizen", "Color": "heat" },
            { "Value": 2, "Label": "Kühlen", "Color": "cold" },
            { "Value": 3, "Label": "Eco",    "Color": "eco"  },
            { "Value": 4, "Label": "Boost",  "Color": "heat" }
          ]
        },
        {
          "type": "CheckBox",
          "name": "AllowTempChange",
          "caption": "Solltemperatur über Kachel änderbar"
        },
        {
          "type": "CheckBox",
          "name": "AllowModeChange",
          "caption": "Modus über Kachel änderbar"
        }
      ]
    },
    {
